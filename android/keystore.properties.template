# Keystore Configuration for Release Builds
# Copy this file to keystore.properties and fill in your values
# DO NOT commit keystore.properties to version control

# Path to your keystore file (relative to project root or absolute path)
storeFile=path/to/your/keystore.jks

# Keystore password
storePassword=your_keystore_password

# Key alias within the keystore
keyAlias=your_key_alias

# Key password
keyPassword=your_key_password
