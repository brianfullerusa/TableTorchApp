<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TableTorch" parent="android:Theme.Material.NoActionBar">
        <!-- Dark window background eliminates white flash on launch for this torch app -->
        <item name="android:windowBackground">@color/dark_blue</item>
        <!-- Edge-to-edge is handled by enableEdgeToEdge() in MainActivity -->
        <!-- Transparent system bars for proper edge-to-edge content -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>