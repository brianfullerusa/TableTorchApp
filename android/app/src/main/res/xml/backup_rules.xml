<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules for Android Auto Backup (API 23-30).
   See https://developer.android.com/guide/topics/data/autobackup
   Note: This file is ignored for devices on API 31+, which use data_extraction_rules.xml
-->
<full-backup-content>
    <!-- Include DataStore preferences for backup -->
    <include domain="file" path="datastore/" />

    <!-- Exclude cache and temporary files -->
    <exclude domain="cache" path="." />
    <exclude domain="no_backup" path="." />
</full-backup-content>
